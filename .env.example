# RetiFlux™ — Supabase Environment Variables
# Copy to .env and fill in your values. NEVER commit .env to git.

# ─────────────────────────────────────────────────────────────────────────────
# SUPABASE (from Dashboard → Project Settings → API)
# ─────────────────────────────────────────────────────────────────────────────

# Public URL — safe for frontend (with RLS)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Anon key — safe for frontend; RLS enforced
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key — BACKEND ONLY. Bypasses RLS. Never expose to client.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─────────────────────────────────────────────────────────────────────────────
# LOCAL DEVELOPMENT (when using supabase start)
# ─────────────────────────────────────────────────────────────────────────────

# Local API URL (default when running supabase start)
# NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321

# Local anon key (run: supabase status to get keys)
# NEXT_PUBLIC_SUPABASE_ANON_KEY=<from supabase status>

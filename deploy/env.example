# Values for Vercel: Project → Settings → Environment Variables
# Or CLI:  vercel env add SUPABASE_URL
# Use Production (and Preview if you want preview deploys to work the same).

# Required for RetiFlux / Supabase client pages
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Optional — banding / Google features (leave empty if unused)
GENERATOR_PASSWORD=
GOOGLE_SHEET_ID=
GOOGLE_API_KEY=
GOOGLE_APPS_SCRIPT_URL=

# Optional — defaults to https://$VERCEL_URL at build time if unset
SCAN_BASE_URL=

# Optional — set to "false" to disable screenshot guard (see js/retiflux-screenshot-guard.js)
SCREENSHOT_GUARD=true
